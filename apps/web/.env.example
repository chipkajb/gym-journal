# Gym Journal — Environment Variables
# Copy this file to .env.local and fill in your values.

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://gymjournal:changeme@localhost:5432/gymjournal"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3001"

# ── AI Name Generator ─────────────────────────────────────────────────────────
# Required for the AI workout name generator feature.
# Get your API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-..."

# ── Optional: Google OAuth ────────────────────────────────────────────────────
# Enables "Continue with Google" on login/register pages.
# GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"
