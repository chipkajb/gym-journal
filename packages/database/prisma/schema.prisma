// Prisma Schema for Gym Journal

generator client {
  provider      = "prisma-client-js"
  output        = "../../../node_modules/.prisma/client"
  // alpine + openssl 3 (node:20-alpine) for docker production image
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// Authentication & User Management
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  password      String? // Hashed password for email/password auth
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts          Account[]
  sessions          Session[]
  profile           Profile?
  workoutTemplates  WorkoutTemplate[]
  workoutSessions   WorkoutSession[]
  deviceConnections DeviceConnection[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================
// User Profile & Preferences
// ============================================

model Profile {
  id               String   @id @default(cuid())
  userId           String   @unique
  bio              String?  @db.Text
  goals            String?  @db.Text
  preferredUnit    String   @default("metric") // metric or imperial
  weekStartsOn     Int      @default(0) // 0 = Sunday, 1 = Monday
  darkModeEnabled  Boolean  @default(false)
  notificationsEnabled Boolean @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ============================================
// Exercise Library (reference; optional for CrossFit-style flows)
// ============================================

model Exercise {
  id               String   @id @default(cuid())
  name             String
  description      String?  @db.Text
  category         String
  muscleGroup      String?  // Primary muscle group
  equipment        String?  // Barbell, Dumbbell, Bodyweight, etc.
  videoUrl         String?
  imageUrl         String?
  instructions     String?  @db.Text
  isCustom         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("exercises")
}

// ============================================
// Workout Templates (CrossFit-style: named WODs)
// ============================================

model WorkoutTemplate {
  id          String   @id @default(cuid())
  userId      String
  title       String   // Workout name (e.g. "DT", "Linda")
  description String?  @db.Text
  scoreType   String?  // Time, Reps, Load, Rounds + Reps, etc.
  barbellLift String?  // Barbell lift name if applicable
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutSessions WorkoutSession[]

  @@map("workout_templates")
}

// ============================================
// Workout Sessions (Logged workouts – one per occurrence)
// ============================================

model WorkoutSession {
  id                 String   @id @default(cuid())
  userId             String
  workoutTemplateId  String?
  title              String
  description        String?  @db.Text
  workoutDate        DateTime // Date of the workout
  bestResultRaw      Float?   // Numeric value for sorting (seconds, reps, load, etc.)
  bestResultDisplay  String?  // Formatted display (e.g. "10:44", "5+2")
  scoreType          String?  // Time, Reps, Load, Rounds + Reps, etc.
  barbellLift        String?
  setDetails         Json?    // Set-by-set details if applicable
  notes              String?  @db.Text
  rxOrScaled         String?  // RX or SCALED
  isPr               Boolean  @default(false)
  // Health & performance metrics (manual entry from smartwatch / in-app timer)
  calories             Int?   // Calories burned
  maxHeartRate         Int?   // Max heart rate (bpm)
  avgHeartRate         Int?   // Average heart rate (bpm)
  totalDurationSeconds Int?   // Total workout time incl. warm-up/cool-down (seconds)
  timedDurationSeconds Int?   // In-app timer result (seconds)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutTemplate WorkoutTemplate? @relation(fields: [workoutTemplateId], references: [id], onDelete: SetNull)

  @@map("workout_sessions")
}

// ============================================
// Smart Device Integration (Future)
// ============================================

model DeviceConnection {
  id           String   @id @default(cuid())
  userId       String
  provider     String // apple_health, google_fit, fitbit, etc.
  accessToken  String   @db.Text
  refreshToken String?  @db.Text
  expiresAt    DateTime?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceData DeviceData[]

  @@unique([userId, provider])
  @@map("device_connections")
}

model DeviceData {
  id                 String   @id @default(cuid())
  deviceConnectionId String
  dataType           String // steps, heart_rate, sleep, calories, etc.
  value              Float
  unit               String
  timestamp          DateTime
  metadata           Json? // Additional metadata
  createdAt          DateTime @default(now())

  deviceConnection DeviceConnection @relation(fields: [deviceConnectionId], references: [id], onDelete: Cascade)

  @@map("device_data")
}
